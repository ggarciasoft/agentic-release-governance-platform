{
  "mcpServers": {
    "release-governance": {
      "command": "dotnet",
      "args": [
        "run",
        "--project",
        "src/ReleaseAssistant.McpServer/ReleaseAssistant.McpServer.csproj"
      ],
      "env": {
        "RELEASE_ASSISTANT_API_BASE_URL": "http://localhost:5050"
      }
    },
    "azure-devops": {
      "command": "npx",
      "args": [
        "-y",
        "@azure-devops/mcp",
        "ggarciasoftOutlook",
        "-d",
        "core",
        "work",
        "work-items",
        "repositories",
        "--authentication",
        "envvar"
      ],
      "env": {
        "ADO_MCP_AUTH_TOKEN": ""
      }
    }
  }
}
