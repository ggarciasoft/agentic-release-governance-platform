{
  "mcpServers": {
    "release-governance": {
      "command": "dotnet",
      "args": [
        "run",
        "--project",
        "src/ReleaseAssistant.McpServer/ReleaseAssistant.McpServer.csproj",
        "--no-launch-profile"
      ],
      "env": {
        "AzureDevOps__Organization": "",
        "AzureDevOps__Project": "",
        "AzureDevOps__Pat": ""
      }
    },
    "azure-devops": {
      "command": "C:\\Users\\..\\AppData\\Roaming\\npm\\mcp-server-azuredevops.cmd",
      "args": [
        "ggarciasoftOutlook",
        "-d",
        "core",
        "work",
        "work-items",
        "repositories",
        "--authentication",
        "envvar"
      ],
      "env": {
        "ADO_MCP_AUTH_TOKEN": "",
        "NODE_OPTIONS": "--use-system-ca"
      }
    }
  }
}
