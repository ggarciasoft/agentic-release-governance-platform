{
  "mcpServers": {
    "release-governance": {
      "command": "dotnet",
      "args": [
        "run",
        "--project",
        "src/ReleaseAssistant.McpServer/ReleaseAssistant.McpServer.csproj"
      ],
      "env": {
        "RELEASE_ASSISTANT_API_BASE_URL": "http://localhost:5000"
      }
    },
    "azure-devops": {
      "command": "npx",
      "args": ["-y", "@azure-devops/mcp"],
      "env": {
        "AZURE_DEVOPS_ORG": "your-org"
      }
    }
  }
}
